# Canonical deployment defaults for the authoritative docker-compose.yaml stack.
# Keep ONOS, OVS, and N6 interface settings here aligned with testbed-env.sh.
ONOS_HOST=192.168.71.160
OVS_HOST=192.168.71.161
ONOS_REST_HOST=192.168.71.160
ONOS_REST_PORT=8181
ONOS_CONTAINER_IP=192.168.71.160
OVS_CONTAINER_IP=192.168.71.161
ONOS_OF_HOST=192.168.71.160
ONOS_OF_PORT=6653
ONOS_AUTH=onos:rocks
ONOS_BASE_URL=http://192.168.71.160:8181
ONOS_CTRL=192.168.71.160:6653

ONOS_CONTAINER_NAME=onos
OVS_CONTAINER_NAME=ovs
OVS_BRIDGE_NAME=br-n6
OVS_UPF_PORT_NAME=v-upf-host
OVS_EDN_PORT_NAME=v-edn-host
OVS_RECONCILE_INTERVAL_SECONDS=5
ONOS_CTRL_TIMEOUT_SECONDS=30
N6_ARP_FORWARD_PRIORITY=45000
N6_BASE_FORWARD_PRIORITY=5000

UPF_CONTAINER_NAME=rfsim5g-oai-upf
UPF_N6_IF=n6ovs0
UPF_N6_IP=192.168.72.134/26
UPF_N6_GW=192.168.72.134
UPF_WAIT_TIMEOUT_SECONDS=120

EXT_DN_CONTAINER_NAME=rfsim5g-oai-ext-dn
EXT_DN_IF=dn0
EXT_DN_N6_IP=192.168.72.135/26
EXT_DN_WAIT_TIMEOUT_SECONDS=120
EXT_DN_WAIT_LOG_INTERVAL_SECONDS=5
EXT_DN_ROUTE_LIST=12.1.1.0/24,12.1.2.0/24,12.1.3.0/24
